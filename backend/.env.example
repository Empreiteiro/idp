# AI Provider: openai | claude | gemini
AI_PROVIDER=openai
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o-mini

# OCR Settings
TESSERACT_PATH=
POPPLER_PATH=

# Database
DATABASE_URL=sqlite:///./data/idp.db

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Classification confidence threshold (0.0-1.0)
CLASSIFICATION_THRESHOLD=0.6

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Encryption key for sensitive settings (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=
